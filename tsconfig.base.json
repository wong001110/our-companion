{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@our-companion/shared": ["packages/shared/src/index.ts"],
      "@our-companion/character-engine": ["packages/character-engine/src/index.ts"],
      "@our-companion/memory-engine": ["packages/memory-engine/src/index.ts"],
      "@our-companion/pattern-engine": ["packages/pattern-engine/src/index.ts"],
      "@our-companion/curiosity-engine": ["packages/curiosity-engine/src/index.ts"],
      "@our-companion/discovery-engine": ["packages/discovery-engine/src/index.ts"],
      "@our-companion/insight-engine": ["packages/insight-engine/src/index.ts"],
      "@our-companion/journey-engine": ["packages/journey-engine/src/index.ts"],
      "@our-companion/diary-engine": ["packages/diary-engine/src/index.ts"],
      "@our-companion/tool-engine": ["packages/tool-engine/src/index.ts"],
      "@our-companion/action-engine": ["packages/action-engine/src/index.ts"],
      "@our-companion/decision-engine": ["packages/decision-engine/src/index.ts"],
      "@our-companion/society-engine": ["packages/society-engine/src/index.ts"],
      "@our-companion/sdk": ["packages/sdk/src/index.ts"],
      "@our-companion/event-bus": ["packages/platform/event-bus/src/index.ts"],
      "@our-companion/ai-engine": ["packages/ai-engine/src/index.ts"],
      "@our-companion/database": ["packages/database/src/index.ts"],
      "@our-companion/speech-engine": ["packages/speech-engine/src/index.ts"],
      "@our-companion/experience-engine": ["packages/experience-engine/src/index.ts"]
    }
  }
}
